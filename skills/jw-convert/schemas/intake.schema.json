{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jw-convert.intake.schema.json",
  "title": "线索成客 partial intake envelope",
  "description": "允许部分输入进入最小追问；不得从缺失字段推断事实。",
  "type": "object",
  "additionalProperties": true,
  "required": [],
  "properties": {
    "lock_baseline": {
      "description": "owner=C10; missing_action=RETURN_C10",
      "x-contract-type": "object",
      "x-owner": "C10",
      "x-minimum": [
        "purchasable_audience",
        "pre_purchase_stage",
        "product_anchor",
        "excluded_audiences",
        "approval_state",
        "version"
      ],
      "x-missing-action": "RETURN_C10",
      "x-provenance-required": true,
      "type": "object"
    },
    "circle_brief": {
      "description": "owner=C20; missing_action=RETURN_C20",
      "x-contract-type": "object",
      "x-owner": "C20",
      "x-minimum": [
        "same_target_audience_and_stage",
        "opening_circle",
        "visual_circle",
        "content_circle",
        "viewpoint_circle",
        "same_person_continuity",
        "approval_state",
        "version"
      ],
      "x-missing-action": "RETURN_C20",
      "x-provenance-required": true,
      "type": "object"
    },
    "product_delivery_facts": {
      "description": "owner=PROJECT_FACT; missing_action=BLOCK_AND_CLARIFY",
      "x-contract-type": "object",
      "x-owner": "PROJECT_FACT",
      "x-minimum": [
        "product_name",
        "delivery_promise",
        "delivery_limitations",
        "evidence_state"
      ],
      "x-missing-action": "BLOCK_AND_CLARIFY",
      "x-provenance-required": true,
      "type": "object"
    },
    "audience_purchase_evidence": {
      "description": "owner=PROJECT_FACT; missing_action=BLOCK_AND_CLARIFY",
      "x-contract-type": "array",
      "x-owner": "PROJECT_FACT",
      "x-minimum": [
        "audience_ref",
        "pre_purchase_concern",
        "recognition_gap",
        "customer_language",
        "evidence_state"
      ],
      "x-missing-action": "BLOCK_AND_CLARIFY",
      "x-provenance-required": true,
      "type": "array"
    },
    "trust_signal_facts": {
      "description": "owner=PROJECT_FACT; missing_action=MARK_UNAVAILABLE_AND_CLARIFY",
      "x-contract-type": "array_or_explicit_none",
      "x-owner": "PROJECT_FACT",
      "x-minimum": [
        "signal_type",
        "factual_basis",
        "audience_meaning",
        "evidence_state"
      ],
      "x-missing-action": "MARK_UNAVAILABLE_AND_CLARIFY",
      "x-provenance-required": true,
      "type": [
        "array",
        "null"
      ]
    },
    "customer_decision_evidence": {
      "description": "owner=PROJECT_FACT; missing_action=MARK_UNAVAILABLE_DO_NOT_FABRICATE",
      "x-contract-type": "array_or_explicit_none",
      "x-owner": "PROJECT_FACT",
      "x-minimum": [
        "similar_customer",
        "problem",
        "hesitation",
        "choice_process",
        "evidence_state"
      ],
      "x-missing-action": "MARK_UNAVAILABLE_DO_NOT_FABRICATE",
      "x-provenance-required": true,
      "type": [
        "array",
        "null"
      ]
    },
    "offer_availability": {
      "description": "optional; owner=PROJECT_FACT",
      "x-contract-type": "object",
      "x-owner": "PROJECT_FACT",
      "type": "object"
    },
    "existing_content_roles": {
      "description": "optional; owner=PROJECT_FACT",
      "x-contract-type": "array",
      "x-owner": "PROJECT_FACT",
      "type": "array"
    },
    "known_purchase_objections": {
      "description": "optional; owner=PROJECT_FACT",
      "x-contract-type": "array",
      "x-owner": "PROJECT_FACT",
      "type": "array"
    }
  },
  "x-contract-ready-required": [
    "lock_baseline",
    "circle_brief",
    "product_delivery_facts",
    "audience_purchase_evidence",
    "trust_signal_facts",
    "customer_decision_evidence"
  ],
  "x-value-origin-enum": [
    "PROJECT_FACT",
    "PROJECT_HYPOTHESIS",
    "REAL_DATA"
  ],
  "x-truth-status-enum": [
    "confirmed",
    "hypothesis",
    "unknown",
    "contradicted"
  ],
  "x-preserve-raw-input": true
}
