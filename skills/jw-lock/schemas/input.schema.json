{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jw-lock.input.schema.json",
  "title": "线索锁客 intake envelope",
  "description": "生产合同就绪输入；部分输入先由 intake.schema.json 接收并进入最小追问。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "positioning_baseline",
    "product_anchor",
    "paid_transaction_evidence",
    "founder_familiarity_evidence",
    "pre_purchase_stage_evidence",
    "pre_purchase_topic_evidence"
  ],
  "properties": {
    "positioning_baseline": {
      "description": "owner=C00; missing_action=RETURN_C00",
      "x-contract-type": "object",
      "x-owner": "C00",
      "x-minimum": [
        "approved_direction",
        "business_and_product_boundary",
        "founder_fit_and_constraints",
        "version",
        "approval_state",
        "payload_hash"
      ],
      "x-missing-action": "RETURN_C00",
      "x-provenance-required": true,
      "type": "object"
    },
    "product_anchor": {
      "description": "owner=PROJECT_FACT; missing_action=BLOCK_AND_CLARIFY",
      "x-contract-type": "object",
      "x-owner": "PROJECT_FACT",
      "x-minimum": [
        "product_name",
        "offer_role",
        "current_price_or_price_state",
        "delivery_promise",
        "delivery_limitations"
      ],
      "x-missing-action": "BLOCK_AND_CLARIFY",
      "x-provenance-required": true,
      "type": "object"
    },
    "paid_transaction_evidence": {
      "description": "owner=PROJECT_FACT; missing_action=MARK_UNVERIFIED_AND_CLARIFY",
      "x-contract-type": "array_or_explicit_none",
      "x-owner": "PROJECT_FACT",
      "x-minimum": [
        "buyer_description",
        "paid_product",
        "actual_price_or_price_state",
        "observed_reason",
        "evidence_state"
      ],
      "x-missing-action": "MARK_UNVERIFIED_AND_CLARIFY",
      "x-provenance-required": true,
      "type": [
        "array",
        "null"
      ]
    },
    "founder_familiarity_evidence": {
      "description": "owner=PROJECT_FACT; missing_action=BLOCK_AND_CLARIFY",
      "x-contract-type": "array",
      "x-owner": "PROJECT_FACT",
      "x-minimum": [
        "audience_candidate",
        "known_concerns",
        "known_hesitations",
        "evidence_state"
      ],
      "x-missing-action": "BLOCK_AND_CLARIFY",
      "x-provenance-required": true,
      "type": "array"
    },
    "pre_purchase_stage_evidence": {
      "description": "owner=PROJECT_FACT; missing_action=BLOCK_AND_CLARIFY",
      "x-contract-type": "array",
      "x-owner": "PROJECT_FACT",
      "x-minimum": [
        "audience_candidate",
        "current_state",
        "attempts_or_failures",
        "why_before_purchase"
      ],
      "x-missing-action": "BLOCK_AND_CLARIFY",
      "x-provenance-required": true,
      "type": "array"
    },
    "pre_purchase_topic_evidence": {
      "description": "owner=PROJECT_FACT; missing_action=BLOCK_AND_CLARIFY",
      "x-contract-type": "array",
      "x-owner": "PROJECT_FACT",
      "x-minimum": [
        "audience_candidate",
        "topic",
        "why_it_matters_before_purchase"
      ],
      "x-missing-action": "BLOCK_AND_CLARIFY",
      "x-provenance-required": true,
      "type": "array"
    },
    "excluded_audiences": {
      "description": "optional; owner=PROJECT_FACT",
      "x-contract-type": "array",
      "x-owner": "PROJECT_FACT",
      "type": "array"
    },
    "failed_audience_attempts": {
      "description": "optional; owner=PROJECT_FACT",
      "x-contract-type": "array",
      "x-owner": "PROJECT_FACT",
      "type": "array"
    },
    "customer_language_samples": {
      "description": "optional; owner=PROJECT_FACT",
      "x-contract-type": "array",
      "x-owner": "PROJECT_FACT",
      "type": "array"
    }
  },
  "x-contract-ready-required": [
    "positioning_baseline",
    "product_anchor",
    "paid_transaction_evidence",
    "founder_familiarity_evidence",
    "pre_purchase_stage_evidence",
    "pre_purchase_topic_evidence"
  ],
  "x-value-origin-enum": [
    "PROJECT_FACT",
    "PROJECT_HYPOTHESIS",
    "REAL_DATA"
  ],
  "x-truth-status-enum": [
    "confirmed",
    "hypothesis",
    "unknown",
    "contradicted"
  ],
  "x-preserve-raw-input": true
}
