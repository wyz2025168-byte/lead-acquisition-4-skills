{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jw-lock.output.schema.json",
  "title": "线索锁客 result envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "artifact_type",
    "decision_class",
    "artifact",
    "failure_codes",
    "route_to",
    "approval_requests"
  ],
  "properties": {
    "capability_id": {
      "const": "C10"
    },
    "artifact_type": {
      "const": "lock_baseline"
    },
    "decision_class": {
      "type": "string",
      "enum": [
        "COMPLETE_FOR_APPROVAL",
        "CONDITIONAL_HYPOTHESIS",
        "NEED_INFO_AND_RETURN_OWNER",
        "REJECT_VIOLATION",
        "RETURN_EARLIEST_DRIFT_OWNER"
      ]
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "positioning_ref": {
          "x-contract-type": "versioned_ref",
          "type": "object",
          "x-owner": "C00"
        },
        "product_anchor": {
          "x-contract-type": "object",
          "type": "object",
          "x-owner": "PROJECT_FACT"
        },
        "purchasable_audience": {
          "x-contract-type": "bounded_statement",
          "type": [
            "string",
            "object"
          ],
          "x-owner": "C10"
        },
        "founder_familiar_audience": {
          "x-contract-type": "bounded_statement",
          "type": [
            "string",
            "object"
          ],
          "x-owner": "C10"
        },
        "pre_purchase_stage": {
          "x-contract-type": "bounded_statement",
          "type": [
            "string",
            "object"
          ],
          "x-owner": "C10"
        },
        "pre_purchase_topics": {
          "x-contract-type": "array",
          "type": "array",
          "x-owner": "C10"
        },
        "four_lock_intersection": {
          "x-contract-type": "bounded_statement",
          "type": [
            "string",
            "object"
          ],
          "x-owner": "C10"
        },
        "excluded_audiences": {
          "x-contract-type": "array",
          "type": "array",
          "x-owner": "C10"
        },
        "transaction_validation": {
          "x-contract-type": "observed_state",
          "type": [
            "string",
            "object"
          ],
          "x-owner": "PROJECT_FACT"
        },
        "truth_status_by_field": {
          "x-contract-type": "object",
          "type": "object",
          "x-owner": "AI_ENGINEERING"
        },
        "approval_state": {
          "x-contract-type": "enum",
          "type": "string",
          "x-owner": "AI_ENGINEERING"
        },
        "uncertainties": {
          "x-contract-type": "array",
          "type": "array",
          "x-owner": "C10"
        },
        "provenance": {
          "x-contract-type": "field_level_refs",
          "type": "object",
          "x-owner": "AI_ENGINEERING"
        },
        "version": {
          "x-contract-type": "string",
          "type": "string",
          "x-owner": "AI_ENGINEERING"
        },
        "payload_hash": {
          "x-contract-type": "sha256",
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "x-owner": "AI_ENGINEERING"
        }
      }
    },
    "failure_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "C10-E001",
          "C10-E002",
          "C10-E003",
          "C10-E004",
          "C10-E005",
          "C10-E006",
          "C10-E007",
          "C10-E008",
          "C10-E009",
          "C10-E010"
        ]
      },
      "uniqueItems": true
    },
    "route_to": {},
    "approval_requests": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "C10-A01",
          "C10-A02",
          "C10-A03",
          "C10-A04"
        ]
      },
      "uniqueItems": true
    }
  },
  "x-normal-artifact-required": [
    "positioning_ref",
    "product_anchor",
    "purchasable_audience",
    "founder_familiar_audience",
    "pre_purchase_stage",
    "pre_purchase_topics",
    "four_lock_intersection",
    "excluded_audiences",
    "transaction_validation",
    "truth_status_by_field",
    "approval_state",
    "uncertainties",
    "provenance",
    "version",
    "payload_hash"
  ],
  "x-partial-artifact-minimum": [
    "truth_status_by_field",
    "approval_state",
    "uncertainties",
    "provenance",
    "version",
    "payload_hash"
  ],
  "x-complete-artifact-schema": "artifact.schema.json",
  "x-payload-hash-canonicalization": "SHA-256 of UTF-8 canonical JSON for artifact excluding payload_hash; sort keys; compact separators; ensure_ascii=false."
}
