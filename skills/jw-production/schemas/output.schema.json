{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jw-production.output.schema.json",
  "title": "制作呈现 result envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "artifact_type",
    "decision_class",
    "artifact",
    "failure_codes",
    "route_to",
    "approval_requests"
  ],
  "properties": {
    "capability_id": {
      "const": "C50"
    },
    "artifact_type": {
      "const": "production_presentation_brief"
    },
    "decision_class": {
      "type": "string",
      "enum": [
        "COMPLETE_FOR_APPROVAL",
        "NEED_INFO_AND_RETURN_OWNER",
        "REJECT_VIOLATION",
        "RETURN_EARLIEST_DRIFT_OWNER",
        "TIME_SENSITIVE_REFERENCE_ONLY"
      ]
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "circle_visual_ref": {
          "x-contract-type": "versioned_ref",
          "type": "object",
          "x-owner": "C20"
        },
        "conversion_presentation_ref": {
          "x-contract-type": "versioned_ref",
          "type": "object",
          "x-owner": "C30"
        },
        "target_audience_ref": {
          "x-contract-type": "versioned_ref",
          "type": "object",
          "x-owner": "C10"
        },
        "content_role": {
          "x-contract-type": "enum",
          "type": "string",
          "x-owner": "C30"
        },
        "audience_scene_and_image_intent": {
          "x-contract-type": "bounded_statement",
          "type": [
            "string",
            "object"
          ],
          "x-owner": "C20"
        },
        "presentation_form": {
          "x-contract-type": "bounded_statement",
          "type": [
            "string",
            "object"
          ],
          "x-owner": "C50"
        },
        "repeatability_plan": {
          "x-contract-type": "object",
          "type": "object",
          "x-owner": "C50"
        },
        "short_video_execution": {
          "x-contract-type": "conditional_object",
          "type": [
            "object",
            "null"
          ],
          "x-owner": "C50"
        },
        "live_image_and_environment": {
          "x-contract-type": "conditional_object",
          "type": [
            "object",
            "null"
          ],
          "x-owner": "C50"
        },
        "fact_and_claim_constraints": {
          "x-contract-type": "array",
          "type": "array",
          "x-owner": "PROJECT_FACT"
        },
        "time_sensitive_references": {
          "x-contract-type": "array",
          "type": "array",
          "x-owner": "C50"
        },
        "current_verification_required": {
          "x-contract-type": "array",
          "type": "array",
          "x-owner": "AI_ENGINEERING"
        },
        "implementation_limits": {
          "x-contract-type": "array",
          "type": "array",
          "x-owner": "C50"
        },
        "uncertainties": {
          "x-contract-type": "array",
          "type": "array",
          "x-owner": "C50"
        },
        "truth_status_by_field": {
          "x-contract-type": "object",
          "type": "object",
          "x-owner": "AI_ENGINEERING"
        },
        "approval_state": {
          "x-contract-type": "enum",
          "type": "string",
          "x-owner": "AI_ENGINEERING"
        },
        "provenance": {
          "x-contract-type": "field_level_refs",
          "type": "object",
          "x-owner": "AI_ENGINEERING"
        },
        "version": {
          "x-contract-type": "string",
          "type": "string",
          "x-owner": "AI_ENGINEERING"
        },
        "payload_hash": {
          "x-contract-type": "sha256",
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "x-owner": "AI_ENGINEERING"
        }
      }
    },
    "failure_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "C50-E001",
          "C50-E002",
          "C50-E003",
          "C50-E004",
          "C50-E005",
          "C50-E006",
          "C50-E007",
          "C50-E008"
        ]
      },
      "uniqueItems": true
    },
    "route_to": {},
    "approval_requests": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "C50-A01",
          "C50-A02",
          "C50-A03",
          "C50-A04"
        ]
      },
      "uniqueItems": true
    }
  },
  "x-normal-artifact-required": [
    "circle_visual_ref",
    "conversion_presentation_ref",
    "target_audience_ref",
    "content_role",
    "audience_scene_and_image_intent",
    "presentation_form",
    "repeatability_plan",
    "short_video_execution",
    "live_image_and_environment",
    "fact_and_claim_constraints",
    "time_sensitive_references",
    "current_verification_required",
    "implementation_limits",
    "uncertainties",
    "truth_status_by_field",
    "approval_state",
    "provenance",
    "version",
    "payload_hash"
  ],
  "x-partial-artifact-minimum": [
    "truth_status_by_field",
    "approval_state",
    "uncertainties",
    "provenance",
    "version",
    "payload_hash"
  ],
  "x-complete-artifact-schema": "artifact.schema.json",
  "x-payload-hash-canonicalization": "SHA-256 of UTF-8 canonical JSON for artifact excluding payload_hash; sort keys; compact separators; ensure_ascii=false."
}
