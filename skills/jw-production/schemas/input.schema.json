{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jw-production.input.schema.json",
  "title": "制作呈现 intake envelope",
  "description": "生产合同就绪输入；部分输入先由 intake.schema.json 接收并进入最小追问。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "circle_visual_brief",
    "conversion_presentation_brief",
    "founder_and_business_constraints",
    "execution_context"
  ],
  "properties": {
    "circle_visual_brief": {
      "description": "owner=C20; missing_action=RETURN_C20",
      "x-contract-type": "versioned_object",
      "x-owner": "C20",
      "x-minimum": [
        "target_audience_ref",
        "pre_purchase_stage_ref",
        "audience_aesthetic_and_trust_intent",
        "scene_and_image_semantics",
        "included_and_excluded_viewers",
        "content_context",
        "approval_state",
        "version"
      ],
      "x-missing-action": "RETURN_C20",
      "x-provenance-required": true,
      "type": "object"
    },
    "conversion_presentation_brief": {
      "description": "owner=C30; missing_action=RETURN_C30",
      "x-contract-type": "versioned_object",
      "x-owner": "C30",
      "x-minimum": [
        "target_audience_ref",
        "content_role",
        "trust_or_purchase_goal",
        "factual_support",
        "claim_constraints",
        "approval_state",
        "version"
      ],
      "x-missing-action": "RETURN_C30",
      "x-provenance-required": true,
      "type": "object"
    },
    "founder_and_business_constraints": {
      "description": "owner=PROJECT_FACT; missing_action=BLOCK_AND_CLARIFY",
      "x-contract-type": "object",
      "x-owner": "PROJECT_FACT",
      "x-minimum": [
        "founder_image_and_expression_constraints",
        "business_context",
        "available_scene",
        "repeatability_constraints",
        "evidence_state"
      ],
      "x-missing-action": "BLOCK_AND_CLARIFY",
      "x-provenance-required": true,
      "type": "object"
    },
    "execution_context": {
      "description": "owner=PROJECT_FACT; missing_action=BLOCK_AND_CLARIFY",
      "x-contract-type": "object",
      "x-owner": "PROJECT_FACT",
      "x-minimum": [
        "medium",
        "intended_use",
        "available_people_space_and_assets",
        "current_constraints"
      ],
      "x-missing-action": "BLOCK_AND_CLARIFY",
      "x-provenance-required": true,
      "type": "object"
    },
    "ideology_route_package": {
      "description": "optional; owner=C90",
      "x-contract-type": "conditional_versioned_object",
      "x-owner": "C90"
    },
    "existing_production_assets": {
      "description": "optional; owner=PROJECT_FACT",
      "x-contract-type": "array",
      "x-owner": "PROJECT_FACT",
      "type": "array"
    },
    "time_sensitive_reference_request": {
      "description": "optional; owner=PROJECT_FACT",
      "x-contract-type": "object_or_explicit_none",
      "x-owner": "PROJECT_FACT"
    },
    "observed_execution_feedback": {
      "description": "optional; owner=REAL_DATA",
      "x-contract-type": "array",
      "x-owner": "REAL_DATA",
      "type": "array"
    }
  },
  "x-contract-ready-required": [
    "circle_visual_brief",
    "conversion_presentation_brief",
    "founder_and_business_constraints",
    "execution_context"
  ],
  "x-value-origin-enum": [
    "PROJECT_FACT",
    "PROJECT_HYPOTHESIS",
    "REAL_DATA"
  ],
  "x-truth-status-enum": [
    "confirmed",
    "hypothesis",
    "unknown",
    "contradicted"
  ],
  "x-preserve-raw-input": true
}
