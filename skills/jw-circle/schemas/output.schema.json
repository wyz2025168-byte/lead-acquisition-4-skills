{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jw-circle.output.schema.json",
  "title": "线索圈客 result envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "artifact_type",
    "decision_class",
    "artifact",
    "failure_codes",
    "route_to",
    "approval_requests"
  ],
  "properties": {
    "capability_id": {
      "const": "C20"
    },
    "artifact_type": {
      "const": "circle_brief"
    },
    "decision_class": {
      "type": "string",
      "enum": [
        "BOUNDARY_COMPLETE_ROUTE_IMPLEMENTATION",
        "COMPLETE_FOR_APPROVAL",
        "NEED_INFO_AND_RETURN_OWNER",
        "REJECT_VIOLATION",
        "RETURN_EARLIEST_DRIFT_OWNER"
      ]
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lock_baseline_ref": {
          "x-contract-type": "versioned_ref",
          "type": "object",
          "x-owner": "C10"
        },
        "same_target_audience_and_stage": {
          "x-contract-type": "bounded_statement",
          "type": [
            "string",
            "object"
          ],
          "x-owner": "C20"
        },
        "opening_circle": {
          "x-contract-type": "object",
          "type": "object",
          "x-owner": "C20"
        },
        "visual_circle": {
          "x-contract-type": "object",
          "type": "object",
          "x-owner": "C20"
        },
        "content_circle": {
          "x-contract-type": "object",
          "type": "object",
          "x-owner": "C20"
        },
        "viewpoint_circle": {
          "x-contract-type": "object",
          "type": "object",
          "x-owner": "C20"
        },
        "same_person_continuity": {
          "x-contract-type": "check_result",
          "type": [
            "string",
            "object"
          ],
          "x-owner": "C20"
        },
        "midstream_switch_risks": {
          "x-contract-type": "array",
          "type": "array",
          "x-owner": "C20"
        },
        "circle_visual_brief": {
          "x-contract-type": "interface_projection",
          "type": "object",
          "x-owner": "C20",
          "x-interface-id": "I-05A",
          "x-projection-fields": [
            "target_audience_ref",
            "pre_purchase_stage_ref",
            "audience_aesthetic_and_trust_intent",
            "scene_and_image_semantics",
            "included_and_excluded_viewers",
            "content_context",
            "approval_state",
            "version"
          ]
        },
        "truth_status_by_field": {
          "x-contract-type": "object",
          "type": "object",
          "x-owner": "AI_ENGINEERING"
        },
        "approval_state": {
          "x-contract-type": "enum",
          "type": "string",
          "x-owner": "AI_ENGINEERING"
        },
        "uncertainties": {
          "x-contract-type": "array",
          "type": "array",
          "x-owner": "C20"
        },
        "provenance": {
          "x-contract-type": "field_level_refs",
          "type": "object",
          "x-owner": "AI_ENGINEERING"
        },
        "version": {
          "x-contract-type": "string",
          "type": "string",
          "x-owner": "AI_ENGINEERING"
        },
        "payload_hash": {
          "x-contract-type": "sha256",
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "x-owner": "AI_ENGINEERING"
        }
      }
    },
    "failure_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "C20-E001",
          "C20-E002",
          "C20-E003",
          "C20-E004",
          "C20-E005",
          "C20-E006",
          "C20-E007",
          "C20-E008",
          "C20-E009",
          "C20-E010"
        ]
      },
      "uniqueItems": true
    },
    "route_to": {},
    "approval_requests": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "C20-A01",
          "C20-A02",
          "C20-A03"
        ]
      },
      "uniqueItems": true
    }
  },
  "x-normal-artifact-required": [
    "lock_baseline_ref",
    "same_target_audience_and_stage",
    "opening_circle",
    "visual_circle",
    "content_circle",
    "viewpoint_circle",
    "same_person_continuity",
    "midstream_switch_risks",
    "circle_visual_brief",
    "truth_status_by_field",
    "approval_state",
    "uncertainties",
    "provenance",
    "version",
    "payload_hash"
  ],
  "x-partial-artifact-minimum": [
    "truth_status_by_field",
    "approval_state",
    "uncertainties",
    "provenance",
    "version",
    "payload_hash"
  ],
  "x-complete-artifact-schema": "artifact.schema.json",
  "x-payload-hash-canonicalization": "SHA-256 of UTF-8 canonical JSON for artifact excluding payload_hash; sort keys; compact separators; ensure_ascii=false."
}
