    "purpose": {
      "core_question": "当前项目该调用哪个已合同化能力、继承哪个批准版本、下一步是什么？",
      "owner_decisions": [
        "读取当前闸门、任务、阻断与批准状态并选择唯一下一路由",
        "维护 C00-C50 成果的 owner、origin、source、version、approval、hash 与 stale 状态",
        "在上游变化或跨模块漂移时定位最早偏差 owner 并定点传播失效",
        "汇总闸门验收、审批点和回归结果",
        "将 validation-only 案例只用于检查组合覆盖、顺序和链路漂移"
      ],
      "non_goals": [
        "不创建、补写或修改 C00-C50 的任何课程方法或业务判断",
        "不把 validation-only 案例提升为规则、阈值、行业基准或结果承诺",
        "不替代用户做不可逆方向、重大规则升级或最终发布审批",
        "不跳过当前闸门或在 G9 前发布",
        "不因一个下游错误整库重写未受影响成果"
      ]
    },
