{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jw-orchestrator.output.schema.json",
  "title": "全案编排器 result envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "artifact_type",
    "decision_class",
    "artifact",
    "failure_codes",
    "route_to",
    "approval_requests"
  ],
  "properties": {
    "capability_id": {
      "const": "C90"
    },
    "artifact_type": {
      "const": "orchestration_summary"
    },
    "decision_class": {
      "type": "string",
      "enum": [
        "NEED_INFO_AND_USER_APPROVAL",
        "REJECT_VIOLATION",
        "RETURN_EARLIEST_DRIFT_OWNER",
        "ROUTE_NEXT",
        "VALIDATION_REPLAY_ONLY"
      ]
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "current_gate": {
          "x-contract-type": "string",
          "type": "string",
          "x-owner": "AI_ENGINEERING"
        },
        "active_task": {
          "x-contract-type": "string",
          "type": "string",
          "x-owner": "AI_ENGINEERING"
        },
        "route_decision": {
          "x-contract-type": "enum",
          "type": "string",
          "x-owner": "AI_ENGINEERING"
        },
        "selected_owner": {
          "x-contract-type": "capability_or_control_owner",
          "type": "string",
          "x-owner": "AI_ENGINEERING"
        },
        "unique_next_task": {
          "x-contract-type": "bounded_statement",
          "type": [
            "string",
            "object"
          ],
          "x-owner": "AI_ENGINEERING"
        },
        "artifact_registry_snapshot": {
          "x-contract-type": "array",
          "type": "array",
          "x-owner": "AI_ENGINEERING"
        },
        "input_versions_and_hashes": {
          "x-contract-type": "array",
          "type": "array",
          "x-owner": "AI_ENGINEERING"
        },
        "dependency_state": {
          "x-contract-type": "object",
          "type": "object",
          "x-owner": "AI_ENGINEERING"
        },
        "stale_targets": {
          "x-contract-type": "array",
          "type": "array",
          "x-owner": "AI_ENGINEERING"
        },
        "earliest_return_owner": {
          "x-contract-type": "capability_or_control_owner_or_null",
          "type": [
            "string",
            "null"
          ],
          "x-owner": "AI_ENGINEERING"
        },
        "gate_result": {
          "x-contract-type": "enum",
          "type": "string",
          "x-owner": "AI_ENGINEERING"
        },
        "validation_replay_state": {
          "x-contract-type": "object",
          "type": "object",
          "x-owner": "AI_ENGINEERING"
        },
        "origin_partition": {
          "x-contract-type": "object",
          "type": "object",
          "x-owner": "AI_ENGINEERING"
        },
        "exclusions": {
          "x-contract-type": "array",
          "type": "array",
          "x-owner": "AI_ENGINEERING"
        },
        "truth_status_by_field": {
          "x-contract-type": "object",
          "type": "object",
          "x-owner": "AI_ENGINEERING"
        },
        "approval_state": {
          "x-contract-type": "enum",
          "type": "string",
          "x-owner": "AI_ENGINEERING"
        },
        "provenance": {
          "x-contract-type": "field_level_refs",
          "type": "object",
          "x-owner": "AI_ENGINEERING"
        },
        "version": {
          "x-contract-type": "string",
          "type": "string",
          "x-owner": "AI_ENGINEERING"
        },
        "payload_hash": {
          "x-contract-type": "sha256",
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "x-owner": "AI_ENGINEERING"
        }
      }
    },
    "failure_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "C90-E001",
          "C90-E002",
          "C90-E003",
          "C90-E004",
          "C90-E005",
          "C90-E006",
          "C90-E007",
          "C90-E008"
        ]
      },
      "uniqueItems": true
    },
    "route_to": {},
    "approval_requests": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "C90-A01",
          "C90-A02",
          "C90-A03",
          "C90-A04"
        ]
      },
      "uniqueItems": true
    }
  },
  "x-normal-artifact-required": [
    "current_gate",
    "active_task",
    "route_decision",
    "selected_owner",
    "unique_next_task",
    "artifact_registry_snapshot",
    "input_versions_and_hashes",
    "dependency_state",
    "stale_targets",
    "earliest_return_owner",
    "gate_result",
    "validation_replay_state",
    "origin_partition",
    "exclusions",
    "truth_status_by_field",
    "approval_state",
    "provenance",
    "version",
    "payload_hash"
  ],
  "x-partial-artifact-minimum": [
    "truth_status_by_field",
    "approval_state",
    "provenance",
    "version",
    "payload_hash"
  ],
  "x-complete-artifact-schema": "artifact.schema.json",
  "x-payload-hash-canonicalization": "SHA-256 of UTF-8 canonical JSON for artifact excluding payload_hash; sort keys; compact separators; ensure_ascii=false."
}
