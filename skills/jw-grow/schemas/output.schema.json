{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jw-grow.output.schema.json",
  "title": "线索生客 result envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "artifact_type",
    "decision_class",
    "artifact",
    "failure_codes",
    "route_to",
    "approval_requests"
  ],
  "properties": {
    "capability_id": {
      "const": "C40"
    },
    "artifact_type": {
      "const": "idea_baseline"
    },
    "decision_class": {
      "type": "string",
      "enum": [
        "APPLY_INTERPRETATION_AND_KEEP_PENDING",
        "COMPLETE_FOR_APPROVAL",
        "NEED_INFO_AND_RETURN_OWNER",
        "REJECT_VIOLATION",
        "RETURN_EARLIEST_DRIFT_OWNER"
      ]
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "positioning_ref": {
          "x-contract-type": "versioned_ref",
          "type": "object",
          "x-owner": "C00"
        },
        "lock_baseline_ref": {
          "x-contract-type": "versioned_ref",
          "type": "object",
          "x-owner": "C10"
        },
        "conversion_brief_ref": {
          "x-contract-type": "versioned_ref",
          "type": "object",
          "x-owner": "C30"
        },
        "core_idea": {
          "x-contract-type": "bounded_statement",
          "type": [
            "string",
            "object"
          ],
          "x-owner": "C40"
        },
        "idea_direction": {
          "x-contract-type": "bounded_statement",
          "type": [
            "string",
            "object"
          ],
          "x-owner": "C40"
        },
        "idea_extension_directions": {
          "x-contract-type": "array",
          "type": "array",
          "x-owner": "C40"
        },
        "idea_expression_rules": {
          "x-contract-type": "object",
          "type": "object",
          "x-owner": "C40"
        },
        "interpretation_trace": {
          "x-contract-type": "object_or_not_applied",
          "type": [
            "object",
            "string",
            "null"
          ],
          "x-owner": "AI_ENGINEERING"
        },
        "practice_evidence": {
          "x-contract-type": "field_level_refs",
          "type": "object",
          "x-owner": "PROJECT_FACT"
        },
        "consistency_filter": {
          "x-contract-type": "object",
          "type": "object",
          "x-owner": "C40"
        },
        "optional_slogan": {
          "x-contract-type": "string_or_none",
          "type": [
            "string",
            "null"
          ],
          "x-owner": "C40"
        },
        "formation_check": {
          "x-contract-type": "observed_state",
          "type": [
            "string",
            "object"
          ],
          "x-owner": "C40"
        },
        "truth_status_by_field": {
          "x-contract-type": "object",
          "type": "object",
          "x-owner": "AI_ENGINEERING"
        },
        "approval_state": {
          "x-contract-type": "enum",
          "type": "string",
          "x-owner": "AI_ENGINEERING"
        },
        "uncertainties": {
          "x-contract-type": "array",
          "type": "array",
          "x-owner": "C40"
        },
        "provenance": {
          "x-contract-type": "field_level_refs",
          "type": "object",
          "x-owner": "AI_ENGINEERING"
        },
        "version": {
          "x-contract-type": "string",
          "type": "string",
          "x-owner": "AI_ENGINEERING"
        },
        "payload_hash": {
          "x-contract-type": "sha256",
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "x-owner": "AI_ENGINEERING"
        }
      }
    },
    "failure_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "C40-E001",
          "C40-E002",
          "C40-E003",
          "C40-E004",
          "C40-E005",
          "C40-E006",
          "C40-E007",
          "C40-E008",
          "C40-E009",
          "C40-E010"
        ]
      },
      "uniqueItems": true
    },
    "route_to": {},
    "approval_requests": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "C40-A01",
          "C40-A02",
          "C40-A03",
          "C40-A04"
        ]
      },
      "uniqueItems": true
    }
  },
  "x-normal-artifact-required": [
    "positioning_ref",
    "lock_baseline_ref",
    "conversion_brief_ref",
    "core_idea",
    "idea_direction",
    "idea_extension_directions",
    "idea_expression_rules",
    "interpretation_trace",
    "practice_evidence",
    "consistency_filter",
    "optional_slogan",
    "formation_check",
    "truth_status_by_field",
    "approval_state",
    "uncertainties",
    "provenance",
    "version",
    "payload_hash"
  ],
  "x-partial-artifact-minimum": [
    "truth_status_by_field",
    "approval_state",
    "uncertainties",
    "provenance",
    "version",
    "payload_hash"
  ],
  "x-complete-artifact-schema": "artifact.schema.json",
  "x-payload-hash-canonicalization": "SHA-256 of UTF-8 canonical JSON for artifact excluding payload_hash; sort keys; compact separators; ensure_ascii=false."
}
