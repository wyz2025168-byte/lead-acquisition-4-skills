{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jw-grow.artifact.schema.json",
  "title": "线索生客 complete artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "positioning_ref",
    "lock_baseline_ref",
    "conversion_brief_ref",
    "core_idea",
    "idea_direction",
    "idea_extension_directions",
    "idea_expression_rules",
    "interpretation_trace",
    "practice_evidence",
    "consistency_filter",
    "optional_slogan",
    "formation_check",
    "truth_status_by_field",
    "approval_state",
    "uncertainties",
    "provenance",
    "version",
    "payload_hash"
  ],
  "properties": {
    "positioning_ref": {
      "x-contract-type": "versioned_ref",
      "type": "object",
      "x-owner": "C00"
    },
    "lock_baseline_ref": {
      "x-contract-type": "versioned_ref",
      "type": "object",
      "x-owner": "C10"
    },
    "conversion_brief_ref": {
      "x-contract-type": "versioned_ref",
      "type": "object",
      "x-owner": "C30"
    },
    "core_idea": {
      "x-contract-type": "bounded_statement",
      "type": [
        "string",
        "object"
      ],
      "x-owner": "C40"
    },
    "idea_direction": {
      "x-contract-type": "bounded_statement",
      "type": [
        "string",
        "object"
      ],
      "x-owner": "C40"
    },
    "idea_extension_directions": {
      "x-contract-type": "array",
      "type": "array",
      "x-owner": "C40"
    },
    "idea_expression_rules": {
      "x-contract-type": "object",
      "type": "object",
      "x-owner": "C40"
    },
    "interpretation_trace": {
      "x-contract-type": "object_or_not_applied",
      "type": [
        "object",
        "string",
        "null"
      ],
      "x-owner": "AI_ENGINEERING"
    },
    "practice_evidence": {
      "x-contract-type": "field_level_refs",
      "type": "object",
      "x-owner": "PROJECT_FACT"
    },
    "consistency_filter": {
      "x-contract-type": "object",
      "type": "object",
      "x-owner": "C40"
    },
    "optional_slogan": {
      "x-contract-type": "string_or_none",
      "type": [
        "string",
        "null"
      ],
      "x-owner": "C40"
    },
    "formation_check": {
      "x-contract-type": "observed_state",
      "type": [
        "string",
        "object"
      ],
      "x-owner": "C40"
    },
    "truth_status_by_field": {
      "x-contract-type": "object",
      "type": "object",
      "x-owner": "AI_ENGINEERING"
    },
    "approval_state": {
      "x-contract-type": "enum",
      "type": "string",
      "x-owner": "AI_ENGINEERING"
    },
    "uncertainties": {
      "x-contract-type": "array",
      "type": "array",
      "x-owner": "C40"
    },
    "provenance": {
      "x-contract-type": "field_level_refs",
      "type": "object",
      "x-owner": "AI_ENGINEERING"
    },
    "version": {
      "x-contract-type": "string",
      "type": "string",
      "x-owner": "AI_ENGINEERING"
    },
    "payload_hash": {
      "x-contract-type": "sha256",
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "x-owner": "AI_ENGINEERING"
    }
  }
}
