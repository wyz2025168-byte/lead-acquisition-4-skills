{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jw-grow.input.schema.json",
  "title": "线索生客 intake envelope",
  "description": "生产合同就绪输入；部分输入先由 intake.schema.json 接收并进入最小追问。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "positioning_baseline",
    "lock_baseline",
    "conversion_journey_brief",
    "founder_value_evidence",
    "product_delivery_facts",
    "existing_content_evidence"
  ],
  "properties": {
    "positioning_baseline": {
      "description": "owner=C00; missing_action=RETURN_C00",
      "x-contract-type": "object",
      "x-owner": "C00",
      "x-minimum": [
        "approved_direction",
        "business_and_product_boundary",
        "founder_fit_and_constraints",
        "approval_state",
        "version"
      ],
      "x-missing-action": "RETURN_C00",
      "x-provenance-required": true,
      "type": "object"
    },
    "lock_baseline": {
      "description": "owner=C10; missing_action=RETURN_C10",
      "x-contract-type": "object",
      "x-owner": "C10",
      "x-minimum": [
        "purchasable_audience",
        "pre_purchase_stage",
        "approval_state",
        "version"
      ],
      "x-missing-action": "RETURN_C10",
      "x-provenance-required": true,
      "type": "object"
    },
    "conversion_journey_brief": {
      "description": "owner=C30; missing_action=RETURN_C30",
      "x-contract-type": "object",
      "x-owner": "C30",
      "x-minimum": [
        "product_fact_ref",
        "immediate_purchase_reason",
        "content_role_plan",
        "idea_role_pointer",
        "consumer_journey",
        "approval_state",
        "version"
      ],
      "x-missing-action": "RETURN_C30",
      "x-provenance-required": true,
      "type": "object"
    },
    "founder_value_evidence": {
      "description": "owner=PROJECT_FACT; missing_action=BLOCK_AND_CLARIFY",
      "x-contract-type": "array",
      "x-owner": "PROJECT_FACT",
      "x-minimum": [
        "belief_or_value_direction",
        "repeated_choice_or_behavior",
        "story_or_experience",
        "evidence_state"
      ],
      "x-missing-action": "BLOCK_AND_CLARIFY",
      "x-provenance-required": true,
      "type": "array"
    },
    "product_delivery_facts": {
      "description": "owner=PROJECT_FACT; missing_action=BLOCK_AND_CLARIFY",
      "x-contract-type": "object",
      "x-owner": "PROJECT_FACT",
      "x-minimum": [
        "product_name",
        "delivery_promise",
        "delivery_limitations",
        "evidence_state"
      ],
      "x-missing-action": "BLOCK_AND_CLARIFY",
      "x-provenance-required": true,
      "type": "object"
    },
    "existing_content_evidence": {
      "description": "owner=PROJECT_FACT; missing_action=MARK_FORMATION_CHECK_PENDING",
      "x-contract-type": "array_or_explicit_none",
      "x-owner": "PROJECT_FACT",
      "x-minimum": [
        "content_ref",
        "expressed_direction",
        "observed_consistency",
        "evidence_state"
      ],
      "x-missing-action": "MARK_FORMATION_CHECK_PENDING",
      "x-provenance-required": true,
      "type": [
        "array",
        "null"
      ]
    },
    "founder_rejected_positions": {
      "description": "optional; owner=PROJECT_FACT",
      "x-contract-type": "array",
      "x-owner": "PROJECT_FACT",
      "type": "array"
    },
    "existing_slogan": {
      "description": "optional; owner=PROJECT_FACT",
      "x-contract-type": "string_or_none",
      "x-owner": "PROJECT_FACT"
    },
    "known_value_conflicts": {
      "description": "optional; owner=PROJECT_FACT",
      "x-contract-type": "array",
      "x-owner": "PROJECT_FACT",
      "type": "array"
    }
  },
  "x-contract-ready-required": [
    "positioning_baseline",
    "lock_baseline",
    "conversion_journey_brief",
    "founder_value_evidence",
    "product_delivery_facts",
    "existing_content_evidence"
  ],
  "x-value-origin-enum": [
    "PROJECT_FACT",
    "PROJECT_HYPOTHESIS",
    "REAL_DATA"
  ],
  "x-truth-status-enum": [
    "confirmed",
    "hypothesis",
    "unknown",
    "contradicted"
  ],
  "x-preserve-raw-input": true
}
