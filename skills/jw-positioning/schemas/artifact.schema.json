{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jw-positioning.artifact.schema.json",
  "title": "定位基座 complete artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "business_and_product_boundary",
    "demand_direction_candidates",
    "competition_mindshare",
    "founder_fit_and_constraints",
    "approved_direction",
    "tradeoff_reasons",
    "discarded_directions",
    "truth_status_by_field",
    "approval_state",
    "uncertainties",
    "provenance",
    "version",
    "payload_hash"
  ],
  "properties": {
    "business_and_product_boundary": {
      "x-contract-type": "bounded_statement",
      "type": [
        "string",
        "object"
      ],
      "x-owner": "C00"
    },
    "demand_direction_candidates": {
      "x-contract-type": "array",
      "type": "array",
      "x-owner": "C00"
    },
    "competition_mindshare": {
      "x-contract-type": "bounded_statement",
      "type": [
        "string",
        "object"
      ],
      "x-owner": "C00"
    },
    "founder_fit_and_constraints": {
      "x-contract-type": "object",
      "type": "object",
      "x-owner": "C00"
    },
    "approved_direction": {
      "x-contract-type": "bounded_statement",
      "type": [
        "string",
        "object"
      ],
      "x-owner": "C00"
    },
    "tradeoff_reasons": {
      "x-contract-type": "array",
      "type": "array",
      "x-owner": "C00"
    },
    "discarded_directions": {
      "x-contract-type": "array",
      "type": "array",
      "x-owner": "C00"
    },
    "truth_status_by_field": {
      "x-contract-type": "object",
      "type": "object",
      "x-owner": "AI_ENGINEERING"
    },
    "approval_state": {
      "x-contract-type": "enum",
      "type": "string",
      "x-owner": "AI_ENGINEERING"
    },
    "uncertainties": {
      "x-contract-type": "array",
      "type": "array",
      "x-owner": "C00"
    },
    "provenance": {
      "x-contract-type": "field_level_refs",
      "type": "object",
      "x-owner": "AI_ENGINEERING"
    },
    "version": {
      "x-contract-type": "string",
      "type": "string",
      "x-owner": "AI_ENGINEERING"
    },
    "payload_hash": {
      "x-contract-type": "sha256",
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "x-owner": "AI_ENGINEERING"
    }
  }
}
